# Build once: docker build -f Dockerfile.base -t ccproxy-base .
# Push to registry if needed: docker tag ccproxy-base ghcr.io/fei2-labs/ccproxy-base && docker push ghcr.io/fei2-labs/ccproxy-base
FROM node:22-slim
RUN apt-get update && apt-get install -y python3 make g++ && rm -rf /var/lib/apt/lists/*
RUN corepack enable && corepack prepare pnpm@10 --activate
